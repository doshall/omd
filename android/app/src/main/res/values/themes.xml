<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Omd" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0d6efd</item>
        <item name="colorPrimaryVariant">#0b5ed7</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:statusBarColor">#1a1b1e</item>
        <item name="android:navigationBarColor">#1a1b1e</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.Omd.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1a1b1e</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Omd</item>
    </style>
</resources>
